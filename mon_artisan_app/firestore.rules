rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['admin']);
    }
    
    function isParticipant(chatData) {
      return request.auth.uid in chatData.participants;
    }
    
    // Collection: users
    match /users/{userId} {
      // Lecture: 
      // - Son propre profil
      // - Admin
      // - Requête par email (pour vérification lors inscription)
      allow read: if isOwner(userId) || 
                     isAdmin() ||
                     // Permettre la recherche par email lors de l'inscription
                     (isAuthenticated() && 
                      request.query.limit <= 1);
      
      // Création: seulement pour soi-même lors de l'inscription
      allow create: if request.auth != null && request.auth.uid == userId;
      
      // Mise à jour: propriétaire ou admin
      allow update: if isOwner(userId) || isAdmin();
      
      // Suppression: admin seulement
      allow delete: if isAdmin();
    }
    
    // Collection: artisans
    match /artisans/{artisanId} {
      // Lecture: tout le monde peut voir les artisans (pour la recherche)
      allow read: if true;
      
      // Création: seulement pour son propre userId
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      
      // Mise à jour: 
      // - Son propre profil
      // - Admin
      // - Système pour marquer disponibilité (lors création/validation commande)
      allow update: if isAuthenticated() && 
                       (resource.data.userId == request.auth.uid || 
                        isAdmin() ||
                        // Permettre mise à jour de disponibilité lors de commandes
                        (request.resource.data.keys().hasOnly(['disponibilite', 'commandeEnCours', 'raisonIndisponibilite', 'dateDebutIndisponibilite', 'dateFinIndisponibilite', 'updatedAt']) &&
                         request.resource.data.keys().hasAny(['disponibilite', 'commandeEnCours'])));
      
      // Suppression: admin seulement
      allow delete: if isAdmin();
    }
    
    // Collection: commandes
    match /commandes/{commandeId} {
      // Lecture: seulement le client, l'artisan concerné ou admin
      allow read: if isAuthenticated() && 
                     (resource.data.clientId == request.auth.uid ||
                      resource.data.artisanId == request.auth.uid ||
                      isAdmin());
      
      // Création: seulement si on est le client
      allow create: if isAuthenticated() && 
                       request.resource.data.clientId == request.auth.uid;
      
      // Mise à jour: seulement le client, l'artisan concerné ou admin
      allow update: if isAuthenticated() && 
                       (resource.data.clientId == request.auth.uid ||
                        resource.data.artisanId == request.auth.uid ||
                        isAdmin());
      
      // Suppression: admin seulement
      allow delete: if isAdmin();
    }
    
    // Collection: agents
    match /agents/{agentId} {
      allow read, write: if isAdmin();
    }
    
    // Collection: chats - SÉCURITÉ RENFORCÉE
    match /chats/{chatId} {
      // Lecture: seulement si on est participant du chat
      allow read: if isAuthenticated() && 
                     request.auth.uid in resource.data.participants;
      
      // Création: seulement si on est dans les participants
      allow create: if isAuthenticated() && 
                       request.auth.uid in request.resource.data.participants;
      
      // Mise à jour: seulement si on est participant
      allow update: if isAuthenticated() && 
                       request.auth.uid in resource.data.participants;
      
      // Suppression: seulement si on est participant
      allow delete: if isAuthenticated() && 
                       request.auth.uid in resource.data.participants;
      
      // Messages dans un chat - SÉCURITÉ RENFORCÉE
      match /messages/{messageId} {
        // Lecture: seulement si on est participant du chat parent
        allow read: if isAuthenticated() && 
                       request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        
        // Création: seulement si on est l'expéditeur ET participant du chat
        allow create: if isAuthenticated() && 
                         request.resource.data.senderId == request.auth.uid &&
                         request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        
        // Mise à jour: seulement pour marquer comme lu si on est le destinataire
        allow update: if isAuthenticated() && 
                         resource.data.receiverId == request.auth.uid &&
                         request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        
        // Suppression: seulement si on est l'expéditeur
        allow delete: if isAuthenticated() && 
                         resource.data.senderId == request.auth.uid;
      }
    }
    
    // Collection: notifications
    match /notifications/{notificationId} {
      // Lecture: seulement ses propres notifications
      allow read: if isAuthenticated() && 
                     resource.data.userId == request.auth.uid;
      
      // Création: 
      // - Admin
      // - Système (lors de création de commande, message, etc.)
      // - Tout utilisateur authentifié peut créer une notification pour un autre
      allow create: if isAuthenticated();
      
      // Mise à jour: seulement ses propres notifications (pour marquer comme lu)
      allow update: if isAuthenticated() && 
                       resource.data.userId == request.auth.uid;
      
      // Suppression: seulement ses propres notifications
      allow delete: if isAuthenticated() && 
                       resource.data.userId == request.auth.uid;
    }
  }
}
